# LinguaLingala — Environment Variables
# Copy this file to .env and fill in values

# FastAPI backend base URL
# In development (with Vite proxy): leave as /api
# In production: set to your full API URL e.g. https://api.yourserver.com
#VITE_API_BASE_URL=/api

# Optional: direct backend URL when not using the Vite proxy
VITE_API_BASE_URL=http://localhost:8000
